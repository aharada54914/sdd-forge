{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sdd-forge/contracts/domain-contract.v1.schema.json",
  "title": "Domain Contract v1",
  "description": "Machine-readable projection of the approved domain model under domain/. Markdown artifacts are human-canonical; this contract is regenerated from them by the domain interviewer and consumed by domain-sync and check-domain-conformance.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "meta", "contexts"],
  "properties": {
    "schema": {
      "const": "domain-contract/v1"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "status", "generated_from"],
      "properties": {
        "version": {
          "type": "string",
          "description": "Monotonic model version, bumped on every regeneration",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Reviewed", "Approved"],
          "description": "Mirror of Domain-Model-Status in domain/context-map.md"
        },
        "generated_from": {
          "type": "array",
          "description": "Repo-relative paths of the Markdown sources this contract was projected from",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "contexts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/boundedContext" }
    },
    "relations": {
      "type": "array",
      "items": { "$ref": "#/definitions/contextRelation" }
    }
  },
  "definitions": {
    "boundedContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "terms", "aggregates"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Canonical context name (kebab-case, EN)",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "description": { "type": "string" },
        "terms": {
          "type": "array",
          "items": { "$ref": "#/definitions/term" }
        },
        "aggregates": {
          "type": "array",
          "items": { "$ref": "#/definitions/aggregate" }
        }
      }
    },
    "term": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical", "definition"],
      "properties": {
        "canonical": {
          "type": "string",
          "description": "Canonical English term as used in specs"
        },
        "ja": {
          "type": "string",
          "description": "Japanese translation"
        },
        "definition": { "type": "string" },
        "forbidden_synonyms": {
          "type": "array",
          "description": "Terms that must not be used in specs for this concept",
          "items": { "type": "string" }
        }
      }
    },
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "root_entity", "invariants", "transaction_boundary", "card"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$",
          "description": "Aggregate name (PascalCase, EN)"
        },
        "root_entity": { "type": "string" },
        "invariants": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "transaction_boundary": {
          "type": "string",
          "description": "What one transaction may span"
        },
        "card": {
          "type": "string",
          "description": "Repo-relative path to domain/aggregates/<name>.md"
        }
      }
    },
    "contextRelation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "pattern"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "pattern": {
          "type": "string",
          "enum": [
            "partnership",
            "shared-kernel",
            "customer-supplier",
            "conformist",
            "anticorruption-layer",
            "open-host-service",
            "published-language",
            "separate-ways"
          ]
        },
        "note": { "type": "string" }
      }
    }
  }
}
