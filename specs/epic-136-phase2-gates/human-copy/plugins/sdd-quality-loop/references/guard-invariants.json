  "shell": {
    "compound_re": "&&|\\|\\||;|\\|",
    "write_arg_cmds": ["tee", "touch", "rm"],
    "write_dest_cmds": ["cp", "mv"],
    "ps_write_cmds": ["set-content", "out-file", "new-item", "remove-item"],
    "indirect_cmds": ["eval", "xargs", "source", "sh", "bash", "zsh", "dash", "ksh"],
    "unsafe_token_chars": ["$", "`", "(", ")", "{", "}", "*", "?", "[", "]"],
    "redirect_token_re": "^(?:\\d*|&)(>>?)([\\s\\S]*)$",
    "fd_dup_re": "^&(?:\\d+|-)$",
    "cd_cmds": ["cd", "pushd"],
    "sudo_write_re": "(?:>|>>|\\btee\\b|\\btouch\\b|\\bcp\\b|\\bmv\\b|\\brm\\b|\\bSet-Content\\b|\\bOut-File\\b|\\bNew-Item\\b|\\bRemove-Item\\b)",
    "read_only_start_re": "^\\s*(?:cat|ls|test|grep|stat|head|tail|rg)\\b"
  },
  "sudo_signature_hex_length": 64,
  "phase2_human_copy_targets": [
